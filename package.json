{
  "name": "nails-salon-system",
  "version": "1.0.0",
  "description": "Nails Salon Management & Booking System",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "husky",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "backend:dev": "npm run dev -w backend",
    "frontend:dev": "npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\""
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": [
      "eslint --config frontend/eslint.config.js --fix",
      "prettier --write"
    ],
    "frontend/src/**/*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1Amaterite/Nails-Salon-System.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/1Amaterite/Nails-Salon-System/issues"
  },
  "homepage": "https://github.com/1Amaterite/Nails-Salon-System#readme",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7"
  }
}
