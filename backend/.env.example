# Database connection URLs (Supabase/PostgreSQL)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD_HERE@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD_HERE@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Server Port
PORT=5001

# JWT Signing Secret (Generate a secure key, e.g. using `openssl rand -hex 64`)
JWT_SECRET=YOUR_JWT_SECRET_HERE

# Node Environment (development/production)
NODE_ENV=development

# Logging Level (info/debug/warn/error/fatal)
LOG_LEVEL=info
