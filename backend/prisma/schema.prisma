datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

generator client {
    provider = "prisma-client-js"
}

// Enums

enum EmployeeRole {
    OWNER
    ADMIN
    STAFF
}

enum AppointmentStatus {
    PENDING
    CONFIRMED
    WAITING
    IN_PROGRESS
    COMPLETED
    CANCELLED
    NO_SHOW
}

enum LoyaltyPointsActionType {
    EARNED
    REDEEMED
    ADJUSTMENT
}

enum PaymentStatus {
    PAID
    REFUNDED
    VOIDED 
}

enum InventoryLogType {
    INBOUND
    USAGE
    ADJUSTMENT
}

// Database Models

model Branch {
    id              String      @id @default(uuid())
    name            String
    address         String?
    phone           String?
    email           String?
    isActive        Boolean     @default(true)

    // Relations
    employees       Employee[]
    services        Service[]
    appointments    Appointment[]
    transactions    Transaction[]
    items           Item[]
    settings        Setting[]
    schedules       EmployeeSchedule[]

    // Timestamps
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt
}

// Clients shared in all of the Branches
model Client {
    id              String      @id @default(uuid())
    firstName       String
    lastName        String
    phoneNumber     String?     @unique
    birthday        DateTime?
    loyaltyPoints   Int         @default(0)
    notes           String?
    deletedAt       DateTime?
    
    // Relations
    appointments    Appointment[]
    transactions    Transaction[]
    loyaltyLedger   LoyaltyLedger[]
    
    // Timestamps
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt

    @@index([firstName, lastName])
}   

model Employee {
    id              String      @id @default(uuid())
    name            String
    username        String?     @unique
    passwordHash    String?     // Nullable, only for admins/owners
    role            EmployeeRole // ADMIN, OWNER, STAFF
    phoneNumber     String
    specialty       String? 
    isActive        Boolean     @default(true)

    // Relations
    branches            Branch[]
    schedules           EmployeeSchedule[]
    appointments        Appointment[]
    transactionServices TransactionService[]
    
    // Timestamps
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt
}

model EmployeeSchedule {
    id              String  @id @default(uuid())
    employeeId      String
    branchId        String
    dayOfWeek       Int
    startTime       String?
    endTime         String?
    isOff           Boolean @default(false)

    // Relations
    employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
    branch          Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)

    // Timestamps
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt

    @@index([employeeId])
    @@index([branchId])
}

model Service {
    id              String      @id @default(uuid())
    name            String
    description     String?
    durationMinutes Int
    bufferTime      Int         @default(5)
    price           Decimal     @db.Decimal(10, 2)
    category        String
    isActive        Boolean     @default(true)
    imageUrl        String?
    branchId        String

    // Relations
    branch              Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
    appointmentServices AppointmentService[]
    transactionServices TransactionService[]

    // Timestamps
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt

    @@index([branchId])
}

model Appointment {
    id              String          @id @default(uuid())
    branchId        String
    clientId        String
    employeeId      String?
    appointmentDate DateTime
    startTime       String?
    endTime         String?
    status          AppointmentStatus
    notes           String?

    // Relations
    branch  Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
    client  Client      @relation(fields: [clientId], references: [id], onDelete: SetNull)
    employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
    services AppointmentService[]
    transactions Transaction[]

    // Timestamps
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt

    @@index([branchId])
    @@index([clientId])
    @@index([employeeId])
    @@index([appointmentDate])
}

model AppointmentService {
    appointmentId   String
    serviceId       String

    // Relations
    appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
    service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    @@id([appointmentId, serviceId])
    @@index([serviceId])
}

model Transaction {
    id              String      @id @default(uuid())
    branchId        String
    appointmentId   String
    clientId        String
    subtotalAmount  Decimal     @db.Decimal(10, 2)
    discountAmount  Decimal     @db.Decimal(10, 2) @default(0)
    taxAmount       Decimal     @db.Decimal(10, 2) @default(0)
    totalAmount     Decimal     @db.Decimal(10, 2)
    paymentMethod   String
    paymentStatus   PaymentStatus

    // Relations
    branch          Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
    appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
    client          Client      @relation(fields: [clientId], references: [id], onDelete: SetNull)
    services        TransactionService[]
    loyaltyLedger   LoyaltyLedger[]

    // Timestamps
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt

    @@index([branchId])
    @@index([appointmentId])
    @@index([clientId])
}

model TransactionService {
    id              String      @id @default(uuid())
    transactionId   String
    serviceId       String
    employeeId      String
    priceCharged    Decimal     @db.Decimal(10, 2)

    // Relations
    transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
    service         Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
    employee        Employee?   @relation(fields: [employeeId], references: [id], onDelete: Restrict)

    // Timestamps
    createdAt       DateTime    @default(now())

    @@index([transactionId])
    @@index([serviceId])
    @@index([employeeId])
}

model LoyaltyLedger {
    id              String      @id @default(uuid())
    clientId        String
    transactionId   String
    pointsChange    Int
    actionType      LoyaltyPointsActionType
    notes           String?

    // Relations
    client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
    transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: SetNull)

    // Timestamps
    createdAt       DateTime    @default(now())

    @@index([clientId])
    @@index([transactionId])
}

model Item {
    id            String         @id @default(uuid())
    branchId      String
    name          String
    description   String?
    sku           String?
    price         Decimal?       @db.Decimal(10, 2)
    cost          Decimal        @default(0.00) @db.Decimal(10, 2)
    stockQuantity Int            @default(0)
    reorderLevel  Int            @default(5)
    isSellable    Boolean        @default(false)

    // Relations
    logs          InventoryLog[]
    branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)

    // Timestamps
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    @@index([branchId])
}

model InventoryLog {
    id             String           @id @default(uuid())
    itemId         String
    quantityChange Int
    logType        InventoryLogType
    notes          String?

    // Relations
    item           Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)

    // Timestamps
    createdAt      DateTime         @default(now())

    @@index([itemId])
}

model Setting {
  key       String   // e.g., "loyalty_earn_rate_ratio", "tax_rate"
  branchId  String
  value     String

  // Relations
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  
  // Timestamps
  updatedAt DateTime @updatedAt

  @@id([branchId, key])
}
