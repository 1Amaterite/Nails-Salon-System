# =============================================================================
# Nails Salon System — Environment Variable Reference
# =============================================================================
# Copy this file to the locations listed below and fill in real values.
# NEVER commit actual secrets to version control.
#
# Backend:  cp .env.example backend/.env
# Frontend: cp .env.example frontend/.env       (only VITE_* vars are used)
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — backend/.env
# ─────────────────────────────────────────────────────────────────────────────

# ── Node.js Runtime ──────────────────────────────────────────────────────────

# Runtime environment. Controls logger format (pretty vs JSON) and whether
# stack traces are included in API error responses.
# Values: "development" | "production" | "test"
NODE_ENV=development

# TCP port the Express server listens on.
# Render.com injects this automatically in production. Default: 5001.
PORT=5001

# ── Authentication ───────────────────────────────────────────────────────────

# HMAC-SHA256 secret used to sign and verify JWT tokens.
# REQUIRED — the server will refuse to start without this value.
# Generate a strong secret with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# ── Database (Supabase / PostgreSQL) ─────────────────────────────────────────

# Prisma runtime connection string — uses Supabase's transaction-mode pooler
# (PgBouncer, port 6543). Add ?pgbouncer=true for connection pooling support.
# Source: backend/prisma/schema.prisma  →  datasource db { url = env("DATABASE_URL") }
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:6543/postgres?pgbouncer=true

# Prisma direct connection — bypasses PgBouncer. Required by Prisma Migrate
# and introspection commands (prisma migrate dev / prisma db push).
# Source: backend/prisma/schema.prisma  →  datasource db { directUrl = env("DIRECT_URL") }
DIRECT_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/postgres

# ── Logging ───────────────────────────────────────────────────────────────────

# Minimum log level emitted by the pino logger.
# Values: "trace" | "debug" | "info" | "warn" | "error" | "fatal"
# Defaults to "info" if not set.
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────────

# The URL of your frontend app. Used to lock down the CORS allowed-origin list
# so only your own frontend can call the API.
# In production, set this to your deployed frontend URL (e.g. Vercel domain).
# In local development this defaults to http://localhost:5173.
FRONTEND_URL=http://localhost:5173


# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND — frontend/.env  (only VITE_* prefix is exposed to the browser)
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────

# Full base URL of the backend API, WITHOUT a trailing slash.
# The app falls back to:
#   - http://localhost:5001  (when running on localhost)
#   - https://nails-salon-backend.onrender.com  (all other hosts)
# Source: frontend/src/utils/getApiUrl.ts, frontend/src/App.tsx
#
# For local development this variable is optional.
# For production deployments (Vercel), set this to your Render backend URL.
VITE_API_URL=http://localhost:5001
